# Copy into Sociatribe .env.local (or merge) after running:
#   pnpm atlas -- bootstrap sociatribe-local --webhook-base http://127.0.0.1:3000
#
# Atlas must be running: pnpm dev   OR   docker compose up

# ── Point Sociatribe at Atlas twins ─────────────────────────────────────────
RAZORPAY_API_BASE_URL=http://127.0.0.1:4400/razorpay
WHATSAPP_GRAPH_BASE_URL=http://127.0.0.1:4400/whatsapp/v22.0

# Optional: load Atlas checkout.js instead of Razorpay CDN in local Playwright
# NEXT_PUBLIC_RAZORPAY_CHECKOUT_JS_URL=http://127.0.0.1:4400/razorpay/checkout.js

# ── Paste values printed by `atlas bootstrap` ───────────────────────────────
# Atlas Razorpay key_id / key_secret / webhook_secret → payment_providers row
# Atlas WhatsApp access_token / phone_number_id / app_secret / verify_token → waba_configs + env

# RAZORPAY_PLATFORM_KEY_ID=
# RAZORPAY_PLATFORM_KEY_SECRET=
# RAZORPAY_PLATFORM_WEBHOOK_SECRET=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# WHATSAPP_APP_SECRET=

# Sociatribe helper script pattern (in Sociatribe package.json):
#   "dev:with-atlas": "concurrently \"pnpm --dir ../atlas dev\" \"pnpm dev\""
